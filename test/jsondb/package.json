{
  "name": "jsondb",
  "version": "0.1.0",
  "description": "基于 Node.js 的轻量级 JSON 数据库，支持 MongoDB 风格语法",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "bin": {
    "jsondb-export": "./bin/cli-export.js",
    "jsondb-import": "./bin/cli-import.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ test/",
    "lint:fix": "eslint src/ test/ --fix",
    "format": "prettier --write \"src/**/*.js\" \"test/**/*.js\"",
    "example": "node examples/basic.js",
    "example:advanced": "node examples/advanced.js",
    "example:jsonb": "node examples/jsonb.js",
    "perf": "node scripts/performance-sqlite.test.js",
    "start": "node bin/server.js",
    "link": "npm link"
  },
  "keywords": [
    "json",
    "database",
    "mongodb",
    "nosql",
    "lightweight",
    "embedded",
    "jsonb"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "vitest": "^1.3.1",
    "xlsx": "^0.18.5"
  },
  "engines": {
    "node": ">=18"
  }
}
