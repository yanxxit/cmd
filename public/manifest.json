    {
      "src": "/favicon.ico",
      "sizes": "192x192",
      "type": "image/x-icon",
      "purpose": "any maskable"
    },
    {
      "src": "/favicon.ico",
      "sizes": "512x512",
      "type": "image/x-icon",
      "purpose": "any maskable"
    }
  ],
  "categories": ["utilities", "productivity", "developer tools"],
  "shortcuts": [
    {
      "name": "TODO",
      "short_name": "TODO",
      "description": "打开 TODO 任务管理",
      "url": "/todo-v7/",
      "icons": [{ "src": "/favicon.ico", "sizes": "96x96" }]
    },
    {
      "name": "Web IDE",
      "short_name": "IDE",
      "description": "打开 Web IDE",
      "url": "/web-ide/",
      "icons": [{ "src": "/favicon.ico", "sizes": "96x96" }]
    },
    {
      "name": "AI 聊天",
      "short_name": "AI",
      "description": "打开 AI 聊天",
      "url": "/ai-chat/",
      "icons": [{ "src": "/favicon.ico", "sizes": "96x96" }]
    },
    {
      "name": "文件查看器",
